{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-flash-free",
  "small_model": "deepseek/deepseek-v4-flash-free",
  "default_agent": "hadith",
  "autoupdate": false,
  "share": "disabled",
  "server": {
    "port": 4096,
    "hostname": "127.0.0.1",
    "cors": ["http://localhost:5173"]
  },
  "mcp": {
    "hadith": {
      "type": "local",
      "command": ["node", "packages/mcp-hadith/dist/index.js"],
      "enabled": true
    },
    "rijal": {
      "type": "local",
      "command": ["node", "packages/mcp-rijal/dist/index.js"],
      "enabled": true
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "deny",
      "curl *sunnah.com*": "allow",
      "curl *quran.com*": "allow"
    }
  },
  "instructions": [
    ".opencode/AGENTS.md",
    ".opencode/skills/arabic-transliteration.md",
    ".opencode/skills/hadith-grading.md",
    ".opencode/skills/usul-al-fiqh.md"
  ]
}
